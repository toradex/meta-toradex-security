From 269b4d1562b3f1f83d01d6be6dcf4de954312367 Mon Sep 17 00:00:00 2001
From: Rogerio Guerra Borin <rogerio.borin@toradex.com>
Date: Mon, 23 Mar 2026 21:52:16 -0300
Subject: [PATCH 06/10] toradex: integrate cp protection (upstream)

This introduces a protection to the "cp" command which only allows it to
write to a limited range of memory matching the protection to the "load"
command.

The new protection is enabled by CONFIG_TDX_CP_PROTECTION. Enabling it,
does not automatically allow the command to pass the whitelist filter.
A separate option CONFIG_TDX_CP_PROTECTION_ALLOW_CMD allows the command
to pass the whitelist. The "cp" protection should be enabled only when
strictly needed (which is the case with Toradex Easy Installer).

Upstream-Status: Inappropriate [Torizon OS specific]
Signed-off-by: Rogerio Guerra Borin <rogerio.borin@toradex.com>
---
 Kconfig   | 20 ++++++++++++++++++++
 cmd/mem.c | 25 +++++++++++++++++++++++++
 2 files changed, 45 insertions(+)

diff --git a/Kconfig b/Kconfig
index 1425c764c93..311f2ee150a 100644
--- a/Kconfig
+++ b/Kconfig
@@ -815,3 +815,23 @@ config TDX_BOOTARGS_PROTECTION
 	  against information in the device-tree provided to the bootm
 	  command. Since the device-tree is supposed to come from a signed
 	  FIT image, it is expected to be a trustworthy source of information.
+
+config TDX_CP_PROTECTION
+	bool "Enable the cp command protection"
+	default n
+	depends on TDX_SECBOOT_HARDENING && TDX_LOAD_PROTECTION
+	help
+	  Enable the protection to the "cp" command, limiting to what addresses
+	  memory copy operations can be performed. To allow the "cp" command to
+	  pass the whitelist, TDX_CP_PROTECTION_ALLOW_CMD must still be set.
+
+config TDX_CP_PROTECTION_ALLOW_CMD
+	bool "Allow the execution of the cp command"
+	default n
+	depends on TDX_CP_PROTECTION
+	help
+	  Allow the execution of the "cp" command (by the whitelist feature) when
+	  that command is protected (hardened). This is aimed mainly to handling
+	  the loading of Toradex Easy Installer. If loading of the installer is
+	  not needed, this option should not be enabled so as to reduce the attack
+	  surface.
diff --git a/cmd/mem.c b/cmd/mem.c
index 768057e4d3f..743753e7907 100644
--- a/cmd/mem.c
+++ b/cmd/mem.c
@@ -21,6 +21,9 @@
 #include <flash.h>
 #endif
 #include <hash.h>
+#ifdef CONFIG_TDX_CP_PROTECTION
+#include <lmb.h>
+#endif
 #include <log.h>
 #include <mapmem.h>
 #include <rand.h>
@@ -335,6 +338,28 @@ static int do_mem_cp(struct cmd_tbl *cmdtp, int flag, int argc,
 		return 1;
 	}
 
+#ifdef CONFIG_TDX_CP_PROTECTION
+#ifndef CONFIG_LMB
+#error TDX_CP_PROTECTION requires CONFIG_LMB to be enabled
+#endif
+	if (gd->fdt_blob) {
+		int tdx_valid_loadaddr(struct lmb *lmb, phys_addr_t base, phys_size_t size);
+		struct lmb lmb;
+
+		lmb_init_and_reserve(&lmb, gd->bd, (void *) gd->fdt_blob);
+		lmb_dump_all(&lmb);
+
+		if (!tdx_valid_loadaddr(&lmb, addr, count * (ulong) size) ||
+		    !tdx_valid_loadaddr(&lmb, dest, count * (ulong) size)) {
+			debug("Invalid source/destination address\n");
+			return 2;
+		}
+	} else {
+		eputs("## ERROR: CP protection is enabled but fdt_blob == NULL\n");
+		return 3;
+	}
+#endif
+
 	src = map_sysmem(addr, count * size);
 	dst = map_sysmem(dest, count * size);
 
